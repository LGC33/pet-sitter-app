                  }
                },
                {
                  "insert": " 1.4. Health: "
                },
                {
                  "insert": "No known medical issues; vaccinations up to date.",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " 1.5. Key Preferences: - Loves "
                },
                {
                  "insert": "fetch",
