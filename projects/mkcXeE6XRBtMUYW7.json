          {
            "type": "text",
            "id": "691104b6-db5f-45e1-8af7-75bb05c6a7ba",
            "text": {
              "ops": [
                {
                  "insert": "Socialization & Group Play",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " 4.1. "
                },
                {
                  "insert": "Temperament Notes",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Friendly and "
                },
                {
                  "insert": "excited around other dogs",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - May become overenthusiastic in group settings; requires "
                },
                {
                  "insert": "active supervision",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". 4.2. "
                },
                {
                  "insert": "Intro to Group Play",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Only introduce to "
                },
                {
                  "insert": "pre-screened, compatible dogs",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " (similar size, play style, and energy level). - Start with "
                },
                {
                  "insert": "1–2 dogs",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " in a "
                },
                {
                  "insert": "fenced, controlled area",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - Keep the first session "
                },
                {
                  "insert": "short (10–15 minutes)",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " and observe closely. 4.3. "
                },
                {
                  "insert": "Supervision Guidelines",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Staff must remain "
                },
                {
                  "insert": "in the play area",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": "; do not supervise from afar. - Watch body language: - Positive signs: loose, wiggly body; play bows; relaxed tail; brief breaks in play. - Concerning signs: stiff posture, raised hackles, prolonged staring, mounting that doesn’t stop when interrupted, snapping or excessive barking. - If play becomes too rough or excited: - Calmly call Charlie away. - Ask for a "
                },
                {
                  "insert": "sit",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " and reward with "
                },
                {
                  "insert": "belly rubs or calm praise",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ", not treats, unless meal/treats are scheduled. - Allow a brief time-out "
                },
                {
                  "insert": "on leash or in a quiet area",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " if needed. 4.4. "
                },
                {
                  "insert": "One-on-One Social Time",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - At least once daily, provide "
                },
                {
                  "insert": "individual staff interaction",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ": - Gentle petting and "
                },
                {
                  "insert": "belly rubs",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " as primary reward. - Light training reinforcement (sit, stay, come, down). - Limit session to "
                },
                {
                  "insert": "10–20 minutes",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " to avoid overstimulation."
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
            "format": {
              "node": "number",
