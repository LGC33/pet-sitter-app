                {
                  "insert": " 1.2. Age: "
                },
                {
                  "insert": "4 years",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " 1.3. Breed: "
                },
                {
                  "insert": "Golden Retriever",
                  "attributes": {
