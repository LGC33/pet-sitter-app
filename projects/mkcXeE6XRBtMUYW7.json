            "completed": false,
            "children": []
          },
          {
            "type": "text",
            "id": "06306dc9-cfd2-4d3a-b4e6-bc84614fa2f0",
            "text": {
              "ops": [
                {
                  "insert": "End-of-Day & Bedtime Routine",
                  "attributes": {
                    "bold": true
                  }
