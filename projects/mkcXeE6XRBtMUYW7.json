            "id": "193ecf57-fa33-465b-adae-0b1d83c7d2a8",
            "text": {
              "ops": [
                {
                  "insert": "Daily Exercise Schedule (2–3 Walks)",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " 2.1. "
                },
                {
                  "insert": "Morning Walk (Primary Walk)",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Time: Between "
                },
                {
                  "insert": "7:00–9:00 a.m.",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " (before or shortly after breakfast). - Duration: "
                },
                {
                  "insert": "20–30 minutes",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ", moderate pace. - Activity: - Start with a "
                },
                {
                  "insert": "5-minute warm-up walk",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " on leash. - Allow short periods of "
                },
                {
                  "insert": "fetch in a secure area",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " if available. - Supervision: - Always "
                },
                {
                  "insert": "on leash",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " outside fenced play yards. - Monitor for signs of overexcitement around other dogs (jumping, lunging, vocalizing). Redirect with calm voice and ask for a “sit” before allowing greeting. 2.2. "
                },
                {
                  "insert": "Midday Walk (Optional/Recommended)",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Time: Between "
                },
                {
                  "insert": "12:00–2:00 p.m.",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Duration: "
                },
                {
                  "insert": "15–20 minutes",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " at a relaxed pace. - Purpose: Potty break, light exercise, mental stimulation. - Activity: - Calm walk on leash, some sniffing time. - Brief fetch session if weather permits and area is secure. 2.3. "
                },
                {
                  "insert": "Evening Walk (Wind-Down Walk)",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Time: Between "
                },
                {
                  "insert": "6:00–8:00 p.m.",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ", after dinner has had at least "
                },
                {
                  "insert": "30 minutes to settle",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - Duration: "
                },
                {
                  "insert": "15–20 minutes",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - Activity: - Gentle walk; no intense running right after eating. - Use this time to let him relax and potty before bedtime."
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
            "format": {
              "node": "number",
