          {
            "type": "text",
            "id": "fdbeb214-42c6-41ae-849c-7283bab19e0f",
            "text": {
              "ops": [
                {
                  "insert": "Safety Protocols – General Handling",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " 6.1. "
                },
                {
                  "insert": "Identification & Check-Ins",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Verify "
                },
                {
                  "insert": "Charlie’s name tag and kennel card",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " at the start of each shift. - Log: feedings, walks, play sessions, and any unusual behavior in the daily record. 6.2. "
                },
                {
                  "insert": "Leash & Handling",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Always use a "
                },
                {
                  "insert": "secure, well-fitted collar or harness",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " and "
                },
                {
                  "insert": "standard leash",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " when outside fenced areas. - Open doors and gates "
                },
                {
                  "insert": "slowly",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " and make sure the area beyond is clear before passing through. - Never tie Charlie unattended. 6.3. "
                },
                {
                  "insert": "Environment & Kennel Safety",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Keep kennel area "
                },
                {
                  "insert": "clean, dry, and free of small or chewable hazards",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - Check toys daily for damage; "
                },
                {
                  "insert": "remove and replace",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " any toy that is torn or has loose parts. - Maintain appropriate "
                },
                {
                  "insert": "temperature and ventilation",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": "."
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
            "format": {
              "node": "number",
              "children": "number"
            },
