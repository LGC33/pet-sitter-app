          {
            "type": "text",
            "id": "af1b1f85-2b5b-46ef-9f40-d38a89e0a18d",
            "text": {
              "ops": [
                {
                  "insert": "Play Activities (Structured & Free Play)",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " 5.1. "
                },
                {
                  "insert": "Fetch Sessions",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Location: "
                },
                {
                  "insert": "Secure, fenced yard or indoor playroom",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " only. - Equipment: - Use facility-approved balls or toys; avoid very small or damaged toys. - Rotate in his "
                },
                {
                  "insert": "blue squeaky toy",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " for comfort, especially in calmer play or pre-bedtime. - Sessions: - 1–2 sessions per day, "
                },
                {
                  "insert": "10–15 minutes",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " each, depending on weather and his energy. - Safety: - Avoid excessive high-impact jumping or long-distance sprints, especially in hot weather. - Offer "
                },
                {
                  "insert": "water breaks",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " during and after play. 5.2. "
                },
                {
                  "insert": "Mental Enrichment",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Provide "
                },
                {
                  "insert": "puzzle feeders",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " or simple scent games (hide kibble or toy in a safe area). - Use "
                },
                {
                  "insert": "short training games",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " with verbal praise and belly rubs as reward. - Avoid food-heavy enrichment beyond his standard diet unless pre-approved. 5.3. "
                },
                {
                  "insert": "Quiet Time & Comfort",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Ensure Charlie has his "
                },
                {
                  "insert": "blue squeaky toy",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " available in his kennel or sleeping area. - Provide "
                },
                {
                  "insert": "soft bedding",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " and maintain a "
                },
                {
                  "insert": "consistent sleep area",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - Dim lights and reduce noise during designated rest periods and at night."
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
            "format": {
