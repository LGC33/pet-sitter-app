          {
            "type": "text",
            "id": "e90c96a7-9c8a-4cf8-a9cf-261c1ab2ad57",
            "text": {
              "ops": [
                {
                  "insert": "Feeding Schedule & Instructions",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " 3.1. "
                },
                {
                  "insert": "Food Type & Amount",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Diet: Owner-provided or facility-approved "
                },
                {
                  "insert": "dry kibble",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - Portion: "
                },
                {
                  "insert": "2 cups of dry food, twice daily",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " (total 4 cups/day). 3.2. "
                },
                {
                  "insert": "Feeding Times",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - "
                },
                {
                  "insert": "Morning Feeding:",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Time: "
                },
                {
                  "insert": "7:00–9:00 a.m.",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Serve "
                },
                {
                  "insert": "2 cups",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " in a clean bowl. - "
                },
                {
                  "insert": "Evening Feeding:",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Time: "
                },
                {
                  "insert": "5:00–7:00 p.m.",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Serve "
                },
                {
                  "insert": "2 cups",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " in a clean bowl. 3.3. "
                },
                {
                  "insert": "Dental Chew",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - After "
                },
                {
                  "insert": "evening meal only",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ", once he has finished his food. - Give "
                },
                {
                  "insert": "1 small dental chew",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - Supervision: - Remain nearby until he finishes to ensure he chews properly and does not gulp. 3.4. "
                },
                {
                  "insert": "Water",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - "
                },
                {
                  "insert": "Fresh water must be available at all times.",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Check and refill bowls: - At minimum: "
                },
                {
                  "insert": "morning, midday, evening, and before lights-out",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ". - Clean water bowl "
                },
                {
                  "insert": "daily",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " or more often if soiled. 3.5. "
                },
                {
                  "insert": "Feeding Safety Protocols",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " - Confirm Charlie’s name before feeding to avoid mix-ups. - Feed "
                },
                {
                  "insert": "individually",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": ", away from other dogs, to prevent food guarding or competition. - Do "
                },
                {
                  "insert": "not",
                  "attributes": {
                    "bold": true
                  }
                },
                {
                  "insert": " add extra food, treats, or table scraps unless specifically authorized by the owner and documented. - Monitor for signs of digestive upset (vomiting, diarrhea, refusing food) and report to supervisor if observed."
                },
                {
                  "insert": "\n",
                  "attributes": {
                    "paragraph": true
                  }
                }
              ]
            },
